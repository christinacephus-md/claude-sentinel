#!/bin/bash
# Claude Sentinel v5.0 - pre-push hook
# Last line of defense: scan outgoing commits for AI trailers that slipped through.
# v5.0: PR size gating — warn about oversized diffs before push.

remote="$1"
url="$2"

FOUND=0

# --- v5.0: PR Size Gating ---
# Configurable thresholds (lines changed)
PR_SIZE_WARN=${CLAUDE_PR_SIZE_WARN:-500}
PR_SIZE_BLOCK=${CLAUDE_PR_SIZE_BLOCK:-2000}

while read local_ref local_sha remote_ref remote_sha; do
  # Skip delete pushes
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi

  # Determine the range to scan
  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # New branch — only scan commits not yet on the default branch
    DEFAULT_BRANCH=$(git symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's@^refs/remotes/origin/@@')
    if [ -z "$DEFAULT_BRANCH" ]; then
      if git rev-parse --verify origin/main >/dev/null 2>&1; then
        DEFAULT_BRANCH="main"
      elif git rev-parse --verify origin/master >/dev/null 2>&1; then
        DEFAULT_BRANCH="master"
      fi
    fi
    if [ -n "$DEFAULT_BRANCH" ]; then
      RANGE="origin/${DEFAULT_BRANCH}..${local_sha}"
    else
      echo "  Warning: Could not determine default branch. Skipping scans."
      continue
    fi
  else
    RANGE="$remote_sha..$local_sha"
  fi

  # --- v5.0: Check diff size ---
  DIFF_STATS=$(git diff --shortstat "$RANGE" 2>/dev/null)
  if [ -n "$DIFF_STATS" ]; then
    # Extract insertions and deletions
    INSERTIONS=$(echo "$DIFF_STATS" | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo "0")
    DELETIONS=$(echo "$DIFF_STATS" | grep -oE '[0-9]+ deletion' | grep -oE '[0-9]+' || echo "0")
    TOTAL_CHANGED=$((${INSERTIONS:-0} + ${DELETIONS:-0}))
    FILES_CHANGED=$(echo "$DIFF_STATS" | grep -oE '[0-9]+ file' | grep -oE '[0-9]+' || echo "0")

    if [ "$TOTAL_CHANGED" -ge "$PR_SIZE_BLOCK" ]; then
      echo ""
      echo "  +---------------------------------------------------------+"
      echo "  |  PR Size Warning: VERY LARGE DIFF                      |"
      echo "  +---------------------------------------------------------+"
      echo ""
      echo "  $DIFF_STATS"
      echo "  Total lines changed: $TOTAL_CHANGED (threshold: $PR_SIZE_BLOCK)"
      echo ""
      echo "  Consider splitting into smaller PRs for easier review."
      echo "  Large PRs have higher defect rates and slower review cycles."
      echo ""
      echo "  To push anyway: git push --no-verify"
      echo ""
      FOUND=1
    elif [ "$TOTAL_CHANGED" -ge "$PR_SIZE_WARN" ]; then
      echo ""
      echo "  PR Size Note: ${TOTAL_CHANGED} lines changed across ${FILES_CHANGED:-?} files."
      echo "  Consider whether this could be split into smaller PRs."
      echo ""
    fi
  fi

  # --- Scan commit messages for AI trailers ---
  LEAKED=$(git log --format="%H %s%n%b" "$RANGE" 2>/dev/null | grep -iE \
    "co-authored-by.*claude|generated.with.*claude|noreply@anthropic" || true)

  if [ -n "$LEAKED" ]; then
    FOUND=1
    echo ""
    echo "  PRE-PUSH BLOCKED: AI-generated trailers detected in outgoing commits."
    echo ""
    echo "  The following commits contain Claude Code attribution markers:"
    echo ""

    git log --format="%h %s" "$RANGE" 2>/dev/null | while read line; do
      SHORT_SHA=$(echo "$line" | awk '{print $1}')
      FULL=$(git log --format="%b" "$SHORT_SHA" -1 2>/dev/null)
      if echo "$FULL" | grep -qiE "co-authored-by.*claude|generated.with.*claude|noreply@anthropic"; then
        echo "    $line"
      fi
    done

    echo ""
    echo "  Fix: Amend or rebase to remove the trailers, then push again."
    echo "  Quick fix for last commit:"
    echo "    git commit --amend"
    echo ""
    echo "  To bypass: git push --no-verify"
    echo ""
  fi
done

if [ "$FOUND" -eq 1 ]; then
  exit 1
fi

exit 0
