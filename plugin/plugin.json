{
  "name": "model-router",
  "version": "4.0.1",
  "description": "Claude Code discipline layer — model routing, cost tracking, git hygiene, session telemetry",
  "author": "Christina Cephus",
  "hooks": {
    "UserPromptSubmit": "hooks/model_router.py",
    "PreToolUse": "hooks/pre_tool_use.sh",
    "PostToolUse": "hooks/post_tool_use.sh",
    "Stop": "hooks/stop_hook.sh"
  },
  "git_hooks": [
    "git-hooks/prepare-commit-msg",
    "git-hooks/commit-msg",
    "git-hooks/pre-push"
  ],
  "components": {
    "routing": "hooks/model_router.py",
    "cost_report": "hooks/cost_report.py",
    "agents": ["agents/router-advisor.md"],
    "commands": ["commands/cost-report.md", "commands/budget-check.md"]
  }
}
