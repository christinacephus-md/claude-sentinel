{
  "version": "7.0.0",
  "description": "18 HIPAA Safe Harbor identifiers — single source of truth for Sentinel + PETRA",
  "usage": "Loaded by sentinel.py (prompt scanning), pre_tool_use.sh (bash scanning), and petra-security agent (code review)",
  "patterns": {
    "patient_medical": "\\b(?:patient|pt)\\s+[A-Z][a-z]+\\s+(?:diagnosis|prescribed|admitted|discharged|treatment)\\b",
    "zip_code": "\\b\\d{5}(?:-\\d{4})?\\b",
    "dob": "\\b(?:DOB|date of birth|born on|admitted|discharged|died)\\s*[:\\-]?\\s*\\d{1,2}[/\\-]\\d{1,2}[/\\-]\\d{2,4}\\b",
    "phone": "\\b(?:\\+1[\\s\\-]?)?\\(?\\d{3}\\)?[\\s\\-]\\d{3}[\\s\\-]\\d{4}\\b",
    "fax": "\\b(?:fax|facsimile)\\s*[:\\-]?\\s*(?:\\+1[\\s\\-]?)?\\(?\\d{3}\\)?[\\s\\-]?\\d{3}[\\s\\-]?\\d{4}\\b",
    "email": "\\b[A-Za-z0-9._%+\\-]+@[A-Za-z0-9.\\-]+\\.[A-Za-z]{2,}\\b",
    "ssn": "\\b(?!000|666|9\\d{2})\\d{3}[- ]?\\d{2}[- ]?\\d{4}\\b",
    "mrn": "\\b(?:MRN|medical record|chart)\\s*[:#]?\\s*\\d{6,10}\\b",
    "health_plan": "\\b(?:beneficiary|member|policy|insurance)\\s*(?:id|#|number)\\s*[:\\-]?\\s*[A-Z0-9]{6,15}\\b",
    "account_number": "\\b(?:account|acct)\\s*[:#]?\\s*\\d{8,12}\\b",
    "license": "\\b(?:DEA|NPI|license)\\s*[:#]?\\s*[A-Z0-9]{7,15}\\b",
    "vin": "\\b[A-HJ-NPR-Z0-9]{17}\\b",
    "device_id": "\\b(?:UDI|device|serial)\\s*[:#]?\\s*[A-Z0-9\\-]{10,20}\\b",
    "patient_url": "\\b(?:patient|portal|mychart)\\S*https?://\\S+\\b",
    "ip_address": "\\b(?:(?:25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\.){3}(?:25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\b",
    "biometric": "\\b(?:fingerprint|voiceprint|retina|iris|facial recognition|biometric)\\s+(?:data|scan|id|record)\\b",
    "photo": "\\b(?:patient|face|headshot|photo)_?\\w*\\.(?:jpg|jpeg|png|gif|bmp|tiff)\\b",
    "patient_id": "\\b(?:patient_id|subscriber_id|member_id)\\s*[=:]\\s*[\"']?[A-Za-z0-9\\-]{6,}\\b"
  }
}
